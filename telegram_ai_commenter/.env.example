OPENAI_API_KEY=sk-...

# Get api_id/api_hash at https://my.telegram.org/apps for each Telegram account.
TG_API_ID_ACCOUNT_1=123456
TG_API_HASH_ACCOUNT_1=0123456789abcdef0123456789abcdef

# Optional Telegram proxy for servers that cannot connect to Telegram directly.
# Leave empty if direct connection works.
TG_PROXY_TYPE=socks5
TG_PROXY_HOST=
TG_PROXY_PORT=
TG_PROXY_USERNAME=
TG_PROXY_PASSWORD=
